<Window x:Class="Foliant.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420"
        Height="310"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Settings fields -->
    <StackPanel Grid.Row="0">
      <!-- Theme -->
      <StackPanel Orientation="Horizontal"
                  Margin="0,0,0,8">
        <TextBlock Text="Theme:"
                   Width="150"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Foreground}" />
        <ComboBox Width="210"
                  ItemsSource="{Binding AvailableThemes}"
                  SelectedItem="{Binding SelectedTheme}" />
      </StackPanel>

      <!-- Language -->
      <StackPanel Orientation="Horizontal"
                  Margin="0,0,0,8">
        <TextBlock Text="Language:"
                   Width="150"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Foreground}" />
        <ComboBox Width="210"
                  ItemsSource="{Binding AvailableLanguages}"
                  SelectedItem="{Binding SelectedLanguage}" />
      </StackPanel>

      <!-- Disk cache limit -->
      <StackPanel Orientation="Horizontal"
                  Margin="0,0,0,8">
        <TextBlock Text="Disk cache limit (GB):"
                   Width="150"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Foreground}" />
        <TextBox Width="80"
                 Text="{Binding DiskCacheLimitGb, StringFormat='{}{0:F1}'}" />
      </StackPanel>

      <!-- Clear on exit -->
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="Clear cache on exit:"
                   Width="150"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Foreground}" />
        <CheckBox IsChecked="{Binding ClearCacheOnExit}"
                  VerticalAlignment="Center" />
      </StackPanel>
    </StackPanel>

    <!-- OK / Cancel buttons -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button Content="OK"
              Width="80"
              Margin="0,0,8,0"
              IsDefault="True"
              Click="OnOkClick" />
      <Button Content="Cancel"
              Width="80"
              IsCancel="True"
              Click="OnCancelClick" />
    </StackPanel>
  </Grid>

</Window>
