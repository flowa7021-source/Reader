<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <SolidColorBrush x:Key="WindowBackground" Color="{x:Static SystemColors.WindowColor}" />
  <SolidColorBrush x:Key="PageBackground" Color="{x:Static SystemColors.ControlColor}" />
  <SolidColorBrush x:Key="TabBackground" Color="{x:Static SystemColors.WindowColor}" />
  <SolidColorBrush x:Key="Foreground" Color="{x:Static SystemColors.WindowTextColor}" />
  <SolidColorBrush x:Key="AccentColor" Color="{x:Static SystemColors.HighlightColor}" />
  <SolidColorBrush x:Key="StatusBarBackground" Color="{x:Static SystemColors.ControlColor}" />

</ResourceDictionary>
