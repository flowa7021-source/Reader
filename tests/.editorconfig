# Test-suite specific overrides. Directory-scoped editorconfig — гарантированно
# применяется ко всем .cs под tests/, в отличие от глобальных glob-секций
# в корневом .editorconfig (которые в .NET-toolchain не всегда матчатся).

[*.cs]
dotnet_diagnostic.CA1707.severity = none      # underscores in test names — норма
dotnet_diagnostic.CA1062.severity = none      # null checks — не нужны
dotnet_diagnostic.CA1031.severity = none      # catch (Exception) в Dispose-cleanup — допустимо
dotnet_diagnostic.CA1001.severity = none      # IAsyncLifetime/xUnit lifecycle — CA1001 не распознаёт
dotnet_diagnostic.CA2000.severity = none      # owned objects тестируются, Dispose делает SUT
dotnet_diagnostic.CA5394.severity = none      # Random для test data — не security
dotnet_diagnostic.CA1822.severity = none      # benchmark-методы могут быть instance, BDN это поддерживает
dotnet_diagnostic.CA1515.severity = none      # public test/benchmark types — допустимо
dotnet_diagnostic.CA1861.severity = none      # tests часто инлайнят массивы в Returns(...) — норма
dotnet_diagnostic.CA1859.severity = none      # тестовые helpers возвращают интерфейс ради читаемости
dotnet_diagnostic.RCS1075.severity = none     # empty catch в test Dispose — best-effort cleanup
